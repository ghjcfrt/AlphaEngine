# hybrid 会将 A 股路由到东方财富非官方行情，将美股路由到 Finnhub/Polygon。
ALPHA_MARKET_DATA_PROVIDER=hybrid

# 美股 REST 行情快照和 WebSocket 实时流。
FINNHUB_API_KEY=replace-me

# 可选的行情快照备用提供方。
POLYGON_API_KEY=replace-me

# 仅用于本地演示；返回确定性的模拟行情，不是真实市场数据。
# ALPHA_MARKET_DATA_PROVIDER=mock

# 仅查询 A 股；使用非官方接口尽力返回行情。
# ALPHA_MARKET_DATA_PROVIDER=eastmoney

ALPHA_REQUEST_TIMEOUT_SECONDS=10
ALPHA_QUOTE_CACHE_TTL_SECONDS=2
